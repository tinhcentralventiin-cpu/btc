{
  "name": "btc-owner-portal-preserve-static",
  "private": true,
  "scripts": {
    "build:js": "esbuild src/main.jsx --bundle --outfile=assets/app.js --format=iife --platform=browser --loader:.js=jsx --loader:.jsx=jsx",
    "build:css": "tailwindcss -i ./src/styles.css -o ./assets/styles.css --minify --content './src/**/*.{js,jsx}' './index.html'",
    "build": "npm run build:js && npm run build:css"
  },
  "dependencies": {
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.0",
    "tailwindcss": "^3.4.17"
  }
}